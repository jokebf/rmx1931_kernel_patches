--- a/drivers/power/oppo/oplus_charger.c
+++ b/drivers/power/oppo/oplus_charger.c
@@ -6216,11 +6216,20 @@ static void oplus_chg_get_chargerid_voltage(struct oplus_chg_chip *chip)
 		charger_xlog_printk(CHG_LOG_CRTI,
 			"get charger id from mcu, chip->chargerid_volt = %d\n",
 			chip->chargerid_volt);
-	} else {
-		if (chip->chg_ops->get_chargerid_switch_val() == 0) {
-			chip->chg_ops->set_chargerid_switch_val(1);
-			oplus_vooc_set_vooc_chargerid_switch_val(1);
-			msleep(100);
-			chip->chargerid_volt = oplus_chg_chargerid_voltage_check(chip);
+	}
+
+	/* Don't touch chargerid switch if VOOC fast charging is active -
+	 * doing so disconnects the data GPIO and kills MCU communication,
+	 * causing "data err:0x70" and unwanted charger suspend.
+	 */
+	if (oplus_vooc_get_fastchg_started() == true) {
+		charger_xlog_printk(CHG_LOG_CRTI,
+			"fastchg active, skip chargerid switch\n");
+	} else if (chip->charger_exist) {
+		if (chip->chg_ops->get_chargerid_switch_val() == 0) {
+			chip->chg_ops->set_chargerid_switch_val(1);
+			oplus_vooc_set_vooc_chargerid_switch_val(1);
+			msleep(100);
+			chip->chargerid_volt = oplus_chg_chargerid_voltage_check(chip);
 		}
 	}
